<?xml version="1.0" encoding="UTF-8"?>
<!--
  Common Torizon OS integration manifest for the NXP NavQ95 (i.MX95), wrynose.

  Base/BSP layer revisions are pinned to NXP's i.MX wrynose manifest
  (imx-manifest imx-6.18.20-2.0.0.xml, Yocto 6.0 / Linux 6.18.20, BSP 2.0.0).
  On top of that it adds the NavQ board layer NXP-Robotics/meta-nxp-mr
  (lf-6.18.2-2.0.0-wrynose-navq95, which fetches kernel/u-boot/SM from the public
  NXP-Robotics repos at AUTOREV), meta-zephyr (Cortex-M7), meta-updater (OTA), and
  the LeoBelmont fork of meta-toradex-torizon (carries the imx95-navqa/b machines).
  See that fork's docs/README-navq95.md for setup/build. Use
  NXP-Robotics/meta-nxp-mr, not the rudislabs fork (that one points i.MX95 at
  private repos).

  meta-toradex-torizon is referenced by branch (fork not yet pinned); everything
  else is pinned. Uses the oe-core split (bitbake + openembedded-core), like NXP's
  manifest, since poky.git has no wrynose branch.
-->
<manifest>

  <default revision="wrynose" sync-j="4"/>

  <remote name="yp"          fetch="https://git.yoctoproject.org"/>
  <remote name="oe"          fetch="https://github.com/openembedded"/>
  <remote name="kraj"        fetch="https://github.com/kraj"/>

  <remote name="community"   fetch="https://github.com/Freescale"/>
  <remote name="ossystems"   fetch="https://github.com/OSSystems"/>
  <remote name="qt"          fetch="https://github.com/YoeDistro"/>
  <remote name="timesys"     fetch="https://github.com/TimesysGit"/>

  <remote name="imx"         fetch="https://github.com/nxp-imx"/>
  <remote name="imx-support" fetch="https://github.com/nxp-imx-support"/>
  <remote name="nxp-robotics" fetch="https://github.com/NXP-Robotics"/>

  <remote name="uptane"      fetch="https://github.com/uptane"/>
  <remote name="navqfork"    fetch="https://github.com/LeoBelmont"/>

  <project name="bitbake" remote="oe" path="sources/bitbake" revision="a2dd9be788274d9c7280be5b1be5eb5c3990cf54" upstream="2.18"/>
  <project name="openembedded-core" remote="oe" path="sources/openembedded-core" revision="42fa856a00ac16b2a7a83d7ecfa60a5be192b16c" upstream="wrynose"/>
