<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <remote alias="repo" fetch="https://git.yoctoproject.org/git" name="yocto"/>
  <remote alias="repo" fetch="https://git.openembedded.org" name="oe"/>
  <remote alias="repo" fetch="https://github.com/uptane" name="uptane"/>
  <remote alias="repo" fetch="https://github.com/torizon" name="torizon"/>

  <default sync-j="4"/>

  <project name="bitbake" path="sources/bitbake" remote="oe" revision="master"/>
  <project name="meta-arm" path="sources/meta-arm" remote="yocto" revision="master"/>
  <project name="meta-ti" path="sources/meta-ti" remote="yocto" revision="master"/>
  <project name="meta-yocto" path="sources/meta-yocto" remote="yocto" revision="master"/>
  <project name="openembedded-core" path="sources/oe-core" remote="oe" revision="master"/>
  <project name="meta-updater" path="sources/meta-updater" remote="uptane" revision="master"/>
  <project name="meta-virtualization" path="sources/meta-virtualization" remote="yocto" revision="master"/>
  <project name="meta-openembedded" path="sources/meta-openembedded" remote="oe" revision="master"/>
  <project name="meta-toradex-torizon" path="sources/meta-toradex-torizon" remote="torizon" revision="master">
    <linkfile dest="setup-environment" src="scripts/setup-environment"/>
  </project>
</manifest>
